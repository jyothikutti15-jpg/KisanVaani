# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Set to false when API keys are configured
MOCK_MODE=true

# Optional: Twilio for real phone calls
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: CORS origins (comma-separated JSON array)
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]

# Optional: Rate limiting (requests per minute)
RATE_LIMIT=30/minute

# Optional: Max input text length (characters)
MAX_INPUT_LENGTH=2000

# Optional: Audio cache cleanup (hours)
AUDIO_CACHE_TTL_HOURS=24
